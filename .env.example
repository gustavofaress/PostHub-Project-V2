# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
# These values should be copied from your existing Supabase project settings
# Project Settings -> API
VITE_SUPABASE_URL="your_supabase_project_url"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Meta / Instagram Graph API
# Create a Meta app with Facebook Login + Instagram Graph API enabled.
META_APP_ID="your_meta_app_id"
META_APP_SECRET="your_meta_app_secret"
META_API_VERSION="v18.0"

# Edge Function callback URL used in the Meta OAuth configuration.
# In hosted Supabase this is usually: https://<project-ref>.supabase.co/functions/v1/meta-callback
META_REDIRECT_URI="https://your-project.supabase.co/functions/v1/meta-callback"

# Secret used to sign the OAuth state payload.
META_STATE_SECRET="generate_a_long_random_secret"

# Secret used by Edge Functions to encrypt Meta access tokens before saving them.
META_TOKEN_ENCRYPTION_KEY="generate_another_long_random_secret"

# Optional secret for cron/worker calls to fetch-instagram-metrics.
META_SYNC_SECRET="optional_cron_secret"

# Meta Conversions API
# Used by the Supabase Edge Function at supabase/functions/meta-conversions.
META_PIXEL_ID="989550670301505"
META_CONVERSIONS_ACCESS_TOKEN="your_meta_conversions_api_access_token"

# Optional: set this while validating events in Meta Events Manager.
META_TEST_EVENT_CODE="TEST12345"

# Stripe Billing
# Used by the Supabase Edge Function at supabase/functions/stripe-webhook.
STRIPE_SECRET_KEY="sk_live_or_test_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PRICE_START="price_1TJcfiLE0cyETHYjbu7xfPYL"
STRIPE_PRICE_GROWTH="price_1TJcfsLE0cyETHYjv9JSmfN7"
STRIPE_PRICE_PRO="price_1TD3N0LE0cyETHYj74Y6NFpn"
